\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces ORC landscape analysis. All values are means over instances per configuration. ``\%ORC'': fraction of local optima where the min-ORC direction leads to a better optimum. ``\%Rand'': same for a random direction (30 trials). ``\%Worst'': same for the max-ORC (most positive curvature) direction. ``Adv.'': ratio \%ORC/\%Rand. The ORC advantage is significant at $p < 0.001$ (paired Wilcoxon signed-rank test) for all non-degenerate configurations ($K > 0$, $\nu > 1$) except $\nu \!=\!16$; see text. $^\dagger $Not significant (negative control; see text).}}{8}{table.1.1}\protected@file@percent }
\newlabel{tab:orc_summary}{{1}{8}{ORC landscape analysis. All values are means over instances per configuration. ``\%ORC'': fraction of local optima where the min-ORC direction leads to a better optimum. ``\%Rand'': same for a random direction (30 trials). ``\%Worst'': same for the max-ORC (most positive curvature) direction. ``Adv.'': ratio \%ORC/\%Rand. The ORC advantage is significant at $p < 0.001$ (paired Wilcoxon signed-rank test) for all non-degenerate configurations ($K > 0$, $\nu > 1$) except $\nu \!=\!16$; see text. $^\dagger $Not significant (negative control; see text)}{table.1.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Fraction of local optima where following the min-ORC, random, or max-ORC (worst) direction leads to a strictly better local optimum. Error bars: standard error over 30 instances (N=16). The ORC advantage is largest at moderate ruggedness, where inter-basin transitions are neither trivial nor impossible.}}{9}{figure.1.1}\protected@file@percent }
\newlabel{fig:advantage}{{1}{9}{Fraction of local optima where following the min-ORC, random, or max-ORC (worst) direction leads to a strictly better local optimum. Error bars: standard error over 30 instances (N=16). The ORC advantage is largest at moderate ruggedness, where inter-basin transitions are neither trivial nor impossible}{figure.1.1}{}}
